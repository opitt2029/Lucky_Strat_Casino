# =========================
# Project
# =========================
PROJECT_NAME=lucky_star_casino

# =========================
# MySQL
# =========================
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=lucky_star_casino
MYSQL_USER=lucky_user
MYSQL_PASSWORD=lucky_password
MYSQL_HOST=localhost
MYSQL_PORT=3307

# =========================
# PostgreSQL
# =========================
POSTGRES_DB=lucky_star_casino
POSTGRES_USER=lucky_user
POSTGRES_PASSWORD=lucky_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379

# =========================
# Kafka
# =========================
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
KAFKA_UI_PORT=8085
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# =========================
# Frontend
# =========================
FRONTEND_PORT=5173

# =========================
# Backend
# =========================
GATEWAY_PORT=8080
MEMBER_SERVICE_PORT=8081
WALLET_SERVICE_PORT=8082
GAME_SERVICE_PORT=8083
RANK_SERVICE_PORT=8084
ADMIN_SERVICE_PORT=8086

# =========================
# Secrets — 必填，無預設值
# =========================
# JWT signing secret（HS256，建議 ≥ 64 chars 隨機字串）
JWT_SECRET=lucky-star-casino-jwt-secret-key-dev-only-change-in-production
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# 內部服務間呼叫共用密鑰（game-service → wallet-service）
INTERNAL_SERVICE_SECRET=lucky-star-internal-secret-dev-only

# 內部服務 URL（容器化部署時改成 service name）
MEMBER_SERVICE_URL=http://localhost:8081
WALLET_SERVICE_URL=http://localhost:8082
GAME_SERVICE_URL=http://localhost:8083
RANK_SERVICE_URL=http://localhost:8084
ADMIN_SERVICE_URL=http://localhost:8086

# Gateway CORS（逗號分隔多個 origin）
CORS_ALLOWED_ORIGINS=http://localhost:5173

# =========================
# JPA / Hibernate
# =========================
# 預設 validate（schema 由 database/*/init.sql 管理）
# 本機開發若想讓 Hibernate 自動建表，改為 update
JPA_DDL_AUTO=validate

# =========================
# Logging（本機 dev 可改 DEBUG）
# =========================
LOG_LEVEL_APP=INFO
LOG_LEVEL_SQL=OFF
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_GATEWAY=INFO
